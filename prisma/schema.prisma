generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mysql"
}


model GameSession {
  id        String   @id @default(uuid())
  chat_id   String   @unique
  type      GameType
  createdAt DateTime @default(now())
}

enum GameType {
  WORD_CHAIN
  PHRASE
}
model Word_Chain {
  id           Int      @id @default(autoincrement())
  last_word    String?
  chat_id      String   @unique
  start_letter String
  used_words   Json
  created_at   DateTime @default(now())
}

model GamePhrase {
  id           String   @id @default(uuid())
  chat_id      String   @unique
  currentRound Int      @default(1)
  phrases      Phrase[]
  createdAt    DateTime @default(now())
}

model Phrase {
  id         String   @id @default(uuid())
  gameId     String
  fullPhrase String
  tip        String
  difficulty String
  category   String
  answers    Answer[]
  Game       GamePhrase     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Answer {
  id        String  @id @default(uuid())
  phraseId  String
  text      String
  isCorrect Boolean
  Phrase    Phrase  @relation(fields: [phraseId], references: [id], onDelete: Cascade)
}

model Box {
  id         Int      @id @default(autoincrement())
  word       String   @unique        
  definition String?
  example    String?
  createdAt  DateTime @default(now())  
  updatedAt  DateTime @updatedAt      

  @@index([word])
}